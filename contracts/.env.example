# Private key of the deployer account on Sepolia (MUST start with 0x)
PRIVATE_KEY=0x...

# RPC URL for the Sepolia testnet (e.g. Infura, Alchemy, etc.)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Etherscan API key for verifying contracts
ETHERSCAN_API_KEY=your-etherscan-api-key

# (Optional) Specific cUSDT token address. Leave blank to deploy the mock automatically.
CUSDT_ADDRESS=
