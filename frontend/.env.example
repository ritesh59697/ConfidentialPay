# Copy to .env and fill in after deploying contracts

# Your deployed InvoiceVault contract address (from: npx hardhat run scripts/deploy.ts --network sepolia)
VITE_INVOICE_VAULT_ADDRESS=0x...

# Zama's cUSDT wrapped token address on Sepolia (check docs.zama.org/protocol)
VITE_CUSDT_ADDRESS=0x...

# Zama relayer URL - use the public testnet relayer or self-host
VITE_RELAYER_URL=https://relayer.testnet.zama.org/v2

# WalletConnect/Reown project id. Add your localhost origin in cloud.reown.com.
VITE_WALLETCONNECT_PROJECT_ID=your-project-id
